# ===========================================
# CONFIGURACIÓN DEL SISTEMA SGE
# ===========================================
# IMPORTANTE: Copiar este archivo como .env y modificar los valores
# NUNCA subir el archivo .env a git

# ===========================================
# BASE DE DATOS
# ===========================================
# Para desarrollo (SQLite):
# DATABASE_URL=sqlite:///sge.db

# Para producción (PostgreSQL):
DATABASE_URL=postgresql://sge_user:CAMBIAR_PASSWORD_SEGURO@localhost:5432/sge_db

# ===========================================
# SEGURIDAD
# ===========================================
# Clave secreta para sesiones (CAMBIAR en producción)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_ESTA_CLAVE_POR_UNA_SEGURA_DE_64_CARACTERES

# Clave para JWT (CAMBIAR en producción)
JWT_SECRET_KEY=CAMBIAR_ESTA_CLAVE_JWT_POR_UNA_SEGURA_DE_64_CARACTERES

# Tiempo de expiración del token JWT (en horas)
JWT_EXPIRATION_HOURS=8

# ===========================================
# RATE LIMITING
# ===========================================
# Límites de peticiones
RATELIMIT_DEFAULT=200 per day
RATELIMIT_LOGIN=5 per minute
RATELIMIT_API=100 per hour

# ===========================================
# CORS (Orígenes permitidos)
# ===========================================
# Separar múltiples orígenes con coma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# MODO DE EJECUCIÓN
# ===========================================
# development | production
ENVIRONMENT=production
DEBUG=False

# ===========================================
# BACKUPS
# ===========================================
BACKUP_DIR=/var/backups/sge
BACKUP_RETENTION_DAYS=30

# ===========================================
# LOGS
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/sge/app.log
